# Nithish Fit — environment variables
#
# The app runs in fully-functional local demo mode (IndexedDB, no network calls) with
# NO environment variables set at all. Only fill these in when you're ready to connect a
# real Supabase project (see README.md "Connecting Supabase").

# Supabase project URL and anon (public) key — found in your Supabase project's
# Settings > API page. Both must be set together to enable Supabase mode; if either is
# missing, the app falls back to local demo mode automatically.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role key, only needed for server-side maintenance scripts (e.g. bulk
# re-seeding the exercise/food reference data via the Supabase CLI). Never expose this to
# the browser — it is not prefixed with NEXT_PUBLIC_ and must never be committed.
SUPABASE_SERVICE_ROLE_KEY=
