# Nithish Fit — environment variables
#
# The app runs in fully-functional local demo mode (IndexedDB, no network calls) with
# NO environment variables set at all. Only fill these in when you're ready to connect a
# real Supabase project (see README.md "Connecting Supabase").

# Supabase project URL and anon (public) key — found in your Supabase project's
# Settings > API page. Both must be set together to enable Supabase mode; if either is
# missing, the app falls back to local demo mode automatically.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role key, needed for server-side maintenance scripts (e.g. bulk
# re-seeding the exercise/food reference data via the Supabase CLI) and for the
# /api/health-import route below. Never expose this to the browser — it is not prefixed
# with NEXT_PUBLIC_ and must never be committed.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Apple Watch calorie sync via the "Health Auto Export" iOS app's REST API
# automation — see README.md "Apple Watch calorie sync" for full setup steps.
# HEALTH_IMPORT_SECRET is a long random string you choose; it's the bearer token the iOS
# app must send. HEALTH_IMPORT_USER_ID is your Supabase auth user id (Authentication > Users
# in the Supabase dashboard). Both required together, along with SUPABASE_SERVICE_ROLE_KEY
# above, or the route returns 503.
HEALTH_IMPORT_SECRET=
HEALTH_IMPORT_USER_ID=
